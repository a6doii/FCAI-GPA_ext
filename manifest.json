{
  "manifest_version": 3,
  "name": "FCAI GPA Calculator",
  "version": "1.0",
  "description": "Calculate GPA, total credit hours, and number of courses from FCAI website.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FCAI GPA Calculator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
